<?xml version="1.0" encoding="utf-8"?>
<xml>
    <target id="haxe">
        <section if="windows">
            <lib name="${haxelib:nakama-haxe}/lib/windows/nakama-sdk.lib"/>
            <lib name="ws2_32.lib" />
            <lib name="crypt32.lib" />
            <lib name="advapi32.lib" />
            <lib name="user32.lib" />
        </section>

        <section if="android">
            <lib name="${haxelib:nakama-haxe}/lib/android/arm64-v8a/nakama-sdk.aar" if="HXCPP_ARM64" />
            <lib name="${haxelib:nakama-haxe}/lib/android/armeabi-v7a/nakama-sdk.aar" if="HXCPP_ARMV7" />
            <lib name="${haxelib:nakama-haxe}/lib/android/x86/nakama-sdk.arr" if="HXCPP_X86" />
            <lib name="${haxelib:nakama-haxe}/lib/android/x86_64/nakama-sdk.arr" if="HXCPP_X86_64" />
        </section>

        <section if="linux">
            <lib name="${haxelib:nakama-haxe}/lib/linux/nakama-sdk.so"/>
        </section>

        <section if="mac">
            <lib name="${haxelib:nakama-haxe}/lib/mac/nakama-sdk.framework"/>
        </section>
    </target>

    <files id="haxe">
        <compilerflag value="-I${haxelib:nakama-haxe}/include" />
        
        <target id="windows">
            <compilerflag value="-L${haxelib:nakama-haxe}/lib/windows" />
        </target>
        
        <target id="linux">
            <compilerflag value="-L${haxelib:nakama-haxe}/lib/linux" />
        </target>
        
        <target id="mac">
            <compilerflag value="-F${haxelib:nakama-haxe}/lib/mac" />
        </target>

        <target id="android">
            <compilerflag value="-F${haxelib:nakama-haxe}/lib/android" />
        </target>
        
        <compilerflag value="-I${haxelib:nakama-haxe}/git/native/include" />
    </files>
</xml>