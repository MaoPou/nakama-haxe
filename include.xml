<xml name="nakama-haxe">

<section if="cpp">

  <!-- 头文件路径（正确写法：name=） -->
  <compilerflag name="-I{nakama-haxe}/lib/nakama/include" />

  <!-- =============================================== -->
  <!-- Windows -->
  <!-- =============================================== -->
  <lib name="{nakama-haxe}/lib/nakama/windows/nakama-sdk.lib" if="windows"/>
  <lib name="ws2_32.lib" if="windows"/>
  <lib name="crypt32.lib" if="windows"/>
  <lib name="user32.lib" if="windows"/>

  <dependency
    path="{nakama-haxe}/lib/nakama/windows/nakama-sdk.dll"
    embed="false"
    if="windows"/>

  <!-- =============================================== -->
  <!-- macOS -->
  <!-- =============================================== -->
  <lib name="-framework nakama-sdk" if="mac"/>
  <lib name="-framework Security" if="mac"/>
  <lib name="-framework CoreFoundation" if="mac"/>
  <lib name="-framework SystemConfiguration" if="mac"/>

  <!-- =============================================== -->
  <!-- Linux -->
  <!-- =============================================== -->
  <lib name="{nakama-haxe}/lib/nakama/linux/libnakama-sdk.so" if="linux"/>
  <lib name="-lpthread" if="linux"/>
  <lib name="-ldl" if="linux"/>
  <lib name="-lssl" if="linux"/>
  <lib name="-lcrypto" if="linux"/>

  <!-- =============================================== -->
  <!-- Android -->
  <!-- =============================================== -->
  <lib name="-llog" if="android"/>
  <lib name="-lz" if="android"/>
  <lib name="-ldl" if="android"/>

  <lib name="{nakama-haxe}/lib/nakama/android/arm64-v8a/libnakama-sdk.so" if="arm64"/>
  <lib name="{nakama-haxe}/lib/nakama/android/armeabi-v7a/libnakama-sdk.so" if="arm"/>
  <lib name="{nakama-haxe}/lib/nakama/android/x86/libnakama-sdk.so" if="x86"/>
  <lib name="{nakama-haxe}/lib/nakama/android/x86_64/libnakama-sdk.so" if="x64"/>

  <!-- =============================================== -->
  <!-- iOS -->
  <!-- =============================================== -->
  <lib name="-framework nakama-sdk" if="ios"/>
  <lib name="-framework Security" if="ios"/>
  <lib name="-framework CoreFoundation" if="ios"/>

</section>

</xml>
